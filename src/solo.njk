<div class="section-wraper">
  <div class="section-title">
    <h1>Solo Registration</h1>
  </div>
  <h3 class="content-subheading">
    Leave your info here and we will find a team for you
  </h3>
  <br />
  <p>
    Already got a team? Register your team
    <a href="/team.html">here</a>
  </p>

  <!-- New Form -->
  <div class="contact-form">
    <form id="form-solo">
      <div class="la-in">
        <label for="fname">Full name</label>
        <input
          type="text"
          id="fname"
          name="entry.2005620554"
          placeholder="Your name"
          required
        />
      </div>

      <div class="la-in">
        <label for="email">E-mail</label>
        <input
          type="email"
          id="email"
          name="entry.1045781291"
          placeholder="Your e-mail"
          required
        />
      </div>

      <div class="la-in">
        <label for="phone">Phone number</label>
        <input
          type="tel"
          id="phone"
          name="entry.1065046570"
          placeholder="Your phone"
          pattern="[\+]?[\d\s\-]{10,15}"
          required
        />
      </div>

      <div class="la-in">
        <label for="dob">Date of birth</label>
        <input
          type="date"
          id="dob"
          name="entry.1166974658"
          placeholder="Your date of birth"
        />
      </div>

      <div class="la-in">
        <label for="address"
          >What area are you based? (post code)
        </label>
        <input
          type="text"
          id="address"
          name="entry.839337160"
          placeholder="Your address"
          required
        />
      </div>

      <div class="la-in">
        <label for="comments">
          <strong>What league do you want to join?</strong>
          <br />
          South West: <strong>Brixton</strong>
          <em>
            <address>SW2 1QS</address>
          </em>
          North London: <strong>North Finchley</strong>
          <em>
            <address>Wren Academy, N12 9HB</address>
          </em>
        </label>
        <textarea
          rows="4"
          id="comments"
          name="entry.96964123"
          placeholder="State your preferred league and some details about yourself"
          required
          aria-describedby="comments-help"
        ></textarea>
        <p class="form-placeholder" id="comments-help">
          Also, please write some details about yourself (position,
          amateur/pro/semipro).
        </p>
      </div>

      <div>
        <div class="errors" aria-live="polite"></div>
        <div id="confirmation">
          <h2>You're in!</h2>
          <p>Thanks for registering. We'll be in touch soon to match you with a team.</p>
          <div>
            <ul>
              <li><a href="/index.html">Back to Home</a></li>
              <li><a href="/solo.html">Register another player</a></li>
              <li><a href="/team.html">Register your team</a></li>
            </ul>
          </div>
        </div>
        <p class="privacy-notice">
          <strong>GDPR</strong> — Your data will be used only to manage
          your participation in LFL leagues and will not be shared with
          third parties.
        </p>
        <p class="privacy-notice">
          By submitting this form, you accept our
          <a href="/privacy.html">Privacy Policy</a>.
        </p>
        <div class="btn-group">
          <input class="btn-s" type="submit" value="Submit" />
          <input
            class="btn-r"
            type="button"
            name="reset_form"
            value="Reset Form"
            onclick="this.form.reset();"
          />
        </div>
      </div>
    </form>
  </div>
</div>
<!-- END New Form -->
