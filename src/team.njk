permalink: "team.html"
---

<div class="section-wraper">
  <div class="section-title">
    <h1>Team Registration for Season 2026</h1>
  </div>
  <h3 class="content-subheading">
    Register your team and will contact you ASAP
  </h3>
  <br />
  <p>
    Looking for a team to join instead?
    <a href="/solo.html">click here</a>
  </p>

  <!-- New form -->
  <div class="contact-form">
    <form
      id="form-team"
      action="https://docs.google.com/forms/u/0/d/e/1FAIpQLSf6MdPJsHIGLcL-GVDkmQ7V_H9u0yjBVI7TfwFhAo7fbecNSA/formResponse"
      method="POST"
    >
      <div class="la-in">
        <label for="tname">Team name</label>
        <input
          type="text"
          id="tname"
          name="entry.2005620554"
          placeholder="Your team's name"
          required
        />
        <p class="form-placeholder">The name of your team</p>
      </div>

      <div class="la-in">
        <label for="aff"
          >Affiliated to any Football Association?</label
        >
        <input
          type="text"
          id="aff"
          name="entry.1045781291"
          placeholder="Yes, No, ..."
          required
        />
        <p class="form-placeholder">
          Please state whether your team is affiliated to any London
          FA. If so, name it.
        </p>
      </div>

      <div class="la-in">
        <label for="kit">Does your team have a kit? </label>
        <input
          type="text"
          id="kit"
          name="entry.1065046570"
          placeholder="Yes, No, ..."
          required
        />
        <p class="form-placeholder">
          If your team has a kit, please give us the details (shirts
          and shorts colours).
        </p>
      </div>

      <div class="la-in">
        <label for="soc">Social media presence</label>
        <input
          type="text"
          id="soc"
          name="entry.1166974658"
          placeholder="Facebook, Twitter, Instagram, ..."
          required
        />
        <p class="form-placeholder">
          List your team's social media accounts.
        </p>
      </div>

      <div class="la-in">
        <label for="tcb">
          <strong>Which league do your team wish to join?</strong>
          <br />
          South West: <strong>Brixton</strong>
          <em>
            <address>SW2 1QS</address>
          </em>
          North London: <strong>North Finchley</strong>
          <em>
            <address>Wren Academy, N12 9HB</address>
          </em>
        </label>
        <textarea
          name="entry.839337160"
          id="tcb"
          placeholder="State your preferred league"
          rows="4"
          required
          aria-describedby="tcb-help"
        ></textarea>
        <p class="form-placeholder" id="tcb-help">
          Also, please state if your team has competed in any other
          futsal League before.
        </p>
      </div>

      <fieldset class="la-in">
        <legend>&nbsp; Person in charge &nbsp;</legend>
        <div class="la-in">
          <label for="pic_name">Name</label>
          <input
            type="text"
            id="pic_name"
            name="entry.901324703"
            placeholder="Person in charge full name"
            required
          />
        </div>
        <div class="la-in">
          <label for="pic_email">E-mail</label>
          <input
            type="email"
            id="pic_email"
            name="entry.1718802261"
            placeholder="Person in charge email"
            required
          />
        </div>
        <div class="la-in">
          <label for="pic_phone">Phone</label>
          <input
            type="tel"
            id="pic_phone"
            name="entry.46084750"
            placeholder="Person in charge phone"
            pattern="[\+]?[\d\s\-]{10,15}"
            required
          />
        </div>
        <div class="la-in">
          <label for="pic_address">Address (post code)</label>
          <input
            type="text"
            id="pic_address"
            name="entry.1314805772"
            placeholder="Person in charge or team address"
            required
          />
        </div>
      </fieldset>

      <div class="la-in">
        <label for="spic">Second person in charge</label>
        <input
          type="text"
          id="spic"
          name="entry.1484949121"
          placeholder="Second person in charge details"
          required
        />
        <p class="form-placeholder">
          Please state full name, phone and email.
        </p>
      </div>

      <div class="la-in">
        <label for="tdescription"
          >Brief description about your team</label
        >
        <textarea
          id="tdescription"
          name="entry.1904350467"
          placeholder="Write some lines about your team"
          required
        ></textarea>
      </div>

      <div>
        <div class="errors" aria-live="polite"></div>
        <div id="confirmation">
          <h2>Team registered!</h2>
          <p>Thanks for signing up. We'll contact you shortly with next steps and season details.</p>
          <div>
            <ul>
              <li><a href="/index.html">Back to Home</a></li>
              <li><a href="/team.html">Register another team</a></li>
              <li><a href="/solo.html">Register as a player</a></li>
            </ul>
          </div>
        </div>
        <p class="privacy-notice">
          <strong>GDPR</strong> — Your data will be used only to manage
          your participation in LFL leagues and will not be shared with
          third parties.
        </p>
        <p class="privacy-notice">
          By submitting this form, you accept our
          <a href="/privacy.html">Privacy Policy</a>.
        </p>
        <div class="btn-group">
          <input class="btn-s" type="submit" value="Submit" />
          <input
            class="btn-r"
            type="button"
            name="reset_form"
            value="Reset Form"
            onclick="this.form.reset();"
          />
        </div>
      </div>
    </form>
  </div>
  <!-- END New form -->
</div>
