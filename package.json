{
  "name": "lfl",
  "version": "1.0.0",
  "description": "The official website for the **London Futsal League**, a community futsal organisation operating across multiple venues in London since 2015.",
  "main": "sw.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "npm run build:html && npm run build:css && npm run build:js",
    "build:html": "eleventy",
    "build:css": "postcss css/*.css --dir _site/css",
    "build:js": "node build-js.js",
    "serve": "eleventy --serve",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gerokal/LFL.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/gerokal/LFL/issues"
  },
  "homepage": "https://github.com/gerokal/LFL#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "terser": "^5.46.0"
  }
}
